# ============================================================
# Harke — Restaurant Backend (NestJS) environment template
# ============================================================
# Copy this file to `.env` and fill in the values.
# `.env` is git-ignored — never commit real secrets.
# ------------------------------------------------------------

# -------- Server --------
PORT=8000

# URL the frontend is served from (used for redirects, CORS, Stripe, password-reset emails)
FRONTEND_URL=http://localhost:3000

# -------- Database (PostgreSQL via Drizzle) --------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/resturant

# -------- JWT (auth & refresh tokens) --------
# Generate strong random strings for production, e.g. `openssl rand -base64 48`
JWT_SECRET=change-me-to-a-long-random-string
JWT_REFRESH_SECRET=change-me-to-another-long-random-string

# -------- Google OAuth (for "Sign in with Google") --------
# Must match NEXT_PUBLIC_GOOGLE_CLIENT_ID on the frontend.
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# -------- Stripe (card payments) --------
# Get test keys at https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_xxx
# Needed only when using Stripe CLI or hosted webhook endpoint.
STRIPE_WEBHOOK_SECRET=whsec_xxx

# -------- Cloudinary (food image uploads) --------
# Dashboard: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# -------- Mailer (password reset emails — Gmail app password works) --------
MAIL_USER=your-mail@gmail.com
MAIL_PASS=your-app-password
